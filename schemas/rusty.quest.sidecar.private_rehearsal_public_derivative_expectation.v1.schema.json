{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rusty.quest.sidecar.private_rehearsal_public_derivative_expectation.v1",
  "title": "Rusty Quest Sidecar Private Rehearsal Public Derivative Expectation",
  "type": "object",
  "required": [
    "schema",
    "expectation_id",
    "generated_at",
    "expectation_status",
    "source_private_rehearsal_evidence_expectation",
    "derivative_scope",
    "authority",
    "expected_public_derivative",
    "manifold_handoff_gate",
    "hostess_escalation_boundary",
    "validation_evidence",
    "privacy_boundary",
    "checks",
    "summary",
    "authority_boundary",
    "next_gate"
  ],
  "properties": {
    "schema": {
      "const": "rusty.quest.sidecar.private_rehearsal_public_derivative_expectation.v1"
    },
    "expectation_id": {
      "type": "string"
    },
    "generated_at": {
