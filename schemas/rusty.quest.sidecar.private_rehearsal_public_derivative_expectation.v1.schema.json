    "source_private_rehearsal_evidence_expectation": {
      "type": "object"
    },
    "derivative_scope": {
      "type": "object"
    },
    "authority": {
      "type": "object"
    },
    "expected_public_derivative": {
      "type": "object"
    },
    "manifold_handoff_gate": {
      "type": "object"
    },
    "hostess_escalation_boundary": {
      "type": "object"
    },
    "validation_evidence": {
      "type": "object"
    },
    "privacy_boundary": {
      "type": "object"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "summary": {
      "type": "object"
    },
    "authority_boundary": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_gate": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
