{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rusty.quest.sidecar.no_network_prototype_handoff_review.v1",
  "title": "Rusty Quest Sidecar No-Network Prototype Handoff Review",
  "type": "object",
  "required": [
    "schema",
    "review_id",
    "generated_at",
    "review_status",
    "source_observation",
    "source_run",
    "integration_status",
    "manifold_mapping",
    "hostess_mapping",
    "checks",
    "summary",
    "authority_boundary",
    "next_gate"
  ],
  "properties": {
    "schema": {
      "const": "rusty.quest.sidecar.no_network_prototype_handoff_review.v1"
    },
    "review_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "review_status": {
      "enum": [
        "handoff_review_ready",
        "manual_review",
        "blocked"
      ]
    },
    "source_observation": {
      "type": "object"
    },
    "source_run": {
      "type": "object"
    },
    "integration_status": {
      "type": "object"
    },
    "manifold_mapping": {
      "type": "object"
    },
    "hostess_mapping": {
      "type": "object"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "summary": {
      "type": "object"
    },
    "authority_boundary": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_gate": {
      "type": "string"
    }
  },
  "additionalProperties": false
}

