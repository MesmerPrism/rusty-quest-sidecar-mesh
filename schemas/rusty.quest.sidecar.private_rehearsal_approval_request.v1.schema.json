{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rusty.quest.sidecar.private_rehearsal_approval_request.v1",
  "title": "Rusty Quest Sidecar Private Rehearsal Approval Request",
  "type": "object",
  "required": [
    "schema",
    "request_id",
    "generated_at",
    "request_status",
    "source_peer_rehearsal_plan",
    "source_contract_intake_request",
    "approval_scope",
    "authority",
    "requested_rehearsal",
    "operator_packet",
    "hostess_boundary",
    "validation_evidence",
    "privacy_boundary",
    "checks",
    "summary",
    "authority_boundary",
    "next_gate"
  ],
  "properties": {
    "schema": {
      "const": "rusty.quest.sidecar.private_rehearsal_approval_request.v1"
    },
    "request_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "request_status": {
      "enum": [
        "operator_approval_required",
        "manual_review",
        "blocked"
      ]
    },
    "source_peer_rehearsal_plan": {
      "type": "object"
    },
    "source_contract_intake_request": {
      "type": "object"
    },
    "approval_scope": {
      "type": "object"
    },
    "authority": {
      "type": "object"
    },
    "requested_rehearsal": {
      "type": "object"
    },
    "operator_packet": {
      "type": "object"
    },
    "hostess_boundary": {
      "type": "object"
    },
    "validation_evidence": {
      "type": "object"
    },
    "privacy_boundary": {
      "type": "object"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "summary": {
      "type": "object"
    },
    "authority_boundary": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_gate": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
